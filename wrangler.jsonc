{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "hackvideo",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-18",
  "observability": { "enabled": true },
  "workers_dev": false,
  "preview_urls": true,
  "routes": [
    { "pattern": "hack5.net", "custom_domain": true },
    { "pattern": "*.hack5.net/*", "zone_name": "hack5.net" }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "hackvideo-db",
      "database_id": "f4b403ff-fd6e-42a0-aa15-7192339f0324"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "SHOTS",
      "id": "40e7013edb944d319a071229c1a1d805"
    }
  ],
  "vars": {
    "APP_NAME": "hack5",
    "EVENT_NAME": "Hackathon",
    "VIDEO_UPLOAD": "off",
    "MAX_VIDEO_BYTES": "83886080",
    "MAX_VIDEO_SECONDS": "180",
    "MIN_SHOTS": "2",
    "MAX_SHOTS": "4",
    "MAX_SHOT_BYTES": "1048576",
    "ROOT_DOMAIN": "hack5.net",
    "CF_ZONE_ID": "c2b830cd9f441a3acedf9dc43c3692dc"
  }
  // R2 (direct video upload) and send_email (OTP) are intentionally omitted for now.
  // To enable R2 video upload later, add:
  //   "r2_buckets": [{ "binding": "VIDEO_BUCKET", "bucket_name": "hackvideo-uploads" }]
  // set VIDEO_UPLOAD=on, and add R2_ACCOUNT_ID / R2_BUCKET_NAME vars + R2 secrets.
}
